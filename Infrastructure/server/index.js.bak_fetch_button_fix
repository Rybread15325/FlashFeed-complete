    res.status(500).json({
      ok: false,
      new_articles: 0,
      ms: Date.now() - t0,
      error: "Fetch endpoint failed"
    });
  }
});

app.get("/api/watch", async (req, res) => {
  res.setHeader("Content-Type", "text/event-stream");
  res.setHeader("Cache-Control", "no-cache");
  res.setHeader("Connection", "keep-alive");

  const interval = Number(req.query.interval || 60);

  res.write(`event: start\n`);
  res.write(`data: ${JSON.stringify({ message: `Auto-watch started. Interval: ${interval}s` })}\n\n`);

  const timer = setInterval(async () => {
    try {
      const db = mongoose.connection.db;
      const totalArticles = await db.collection("articles").countDocuments();

      res.write(`event: line\n`);
      res.write(`data: ${JSON.stringify({ text: `Cycle #${Date.now()} — ${totalArticles} articles currently stored` })}\n\n`);
    } catch (err) {
      res.write(`event: error\n`);
      res.write(`data: ${JSON.stringify({ message: "Watch cycle failed" })}\n\n`);
    }
  }, interval * 1000);

  req.on("close", () => {
    clearInterval(timer);
  });
});
