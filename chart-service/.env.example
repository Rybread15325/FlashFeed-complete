# chart-service environment (copy to chart-service/.env and fill in; .env is gitignored)

# Finviz Elite token — our canonical name. Required for candle data.
# (Ryan's repo historically used FINVIZ_AUTH_TOKEN; this service accepts that as a
#  fallback, but FINVIZ_TOKEN is the standard going forward.)
FINVIZ_TOKEN=

# Port the Flask service listens on (default 5050, matching sentiment-scout).
PORT=5050

# Social overlays — SQLite seed fallback: path to a point-in-time snapshot
# (a copy of sentiment-scout/sentiment_screener.db) holding ticker_insights.
# Default: chart-service/social_snapshot.db (gitignored — real data, never commit).
# Used only when a live StockTwits walk returns nothing.
SOCIAL_DB_PATH=

# Phase 2b live backfill store (MongoDB). chart-service uses its OWN db/collection
# by default so it is DECOUPLED from sentiment-scout's sentiment_scout.social_history
# (a failed/rate-limited walk here can never mask the dashboard's data, and vice
# versa). If Mongo is unreachable, the store falls back to in-memory (process-life).
MONGO_URI=mongodb://localhost:27017
MONGO_DB=flashfeed
MONGO_COLL=social_history

# Comma-separated CORS allowlist for the frontend origin (default: Vite dev).
FRONTEND_ORIGIN=http://localhost:5173
