FROM python:3.12-slim

WORKDIR /app

COPY 1_News ./1_News
COPY Infrastructure/kafka ./Infrastructure/kafka

RUN pip install --no-cache-dir pymongo feedparser requests curl_cffi python-dotenv "psycopg[binary]" confluent-kafka redis

ENV PYTHONUNBUFFERED=1
ENV RSS_COOLDOWN_SECONDS=0
ENV RSS_STATE_FILE=/tmp/feedflash_rss_fetch_state.json

CMD ["python", "1_News/pipeline/fetch_rss_to_mongo.py"]
